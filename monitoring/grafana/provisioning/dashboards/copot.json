{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "CoPot — Vue d'ensemble",
  "tags": ["copot"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Backend up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "copot_up", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "Utilisateurs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "copot_users_total", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "Comptes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "copot_accounts_total", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Opérations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "copot_transactions_total", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "Croissance des opérations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        { "expr": "copot_transactions_total", "legendFormat": "opérations", "refId": "A" },
        { "expr": "copot_accounts_total", "legendFormat": "comptes", "refId": "B" },
        { "expr": "copot_users_total", "legendFormat": "utilisateurs", "refId": "C" }
      ]
    }
  ]
}
