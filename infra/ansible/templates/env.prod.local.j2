APP_SECRET={{ copot_app_secret }}
CORS_ALLOW_ORIGIN='^https://{{ copot_domain }}$'

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE={{ copot_jwt_passphrase }}

MAILER_DSN={{ copot_mailer_dsn }}

GOOGLE_CLIENT_ID={{ copot_google_client_id | default('') }}
GOOGLE_CLIENT_SECRET={{ copot_google_client_secret | default('') }}

FRONTEND_URL=https://{{ copot_domain }}
DEFAULT_URI=https://{{ copot_domain }}
PASSWORD_ROTATION_DAYS=60
