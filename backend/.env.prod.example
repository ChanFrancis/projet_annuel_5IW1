# CoPot — production environment template.
#
# Copy to backend/.env.prod.local and fill with REAL secrets:
#   cp backend/.env.prod.example backend/.env.prod.local
#
# backend/.env.prod.local is git-ignored. Never commit real secrets.
# Values here mirror docker-compose.prod.yml (which injects DATABASE_URL /
# REDIS_URL / APP_ENV / APP_DEBUG itself, so those are listed for reference).

### Application
APP_SECRET=__generate_a_64char_random_string__
# APP_ENV / APP_DEBUG / DATABASE_URL / REDIS_URL are injected by docker-compose.prod.yml.

### CORS — same-origin in prod (SPA calls /api via Traefik), so allow nothing extra.
CORS_ALLOW_ORIGIN='^https://__DOMAIN__$'

### JWT — passphrase used to encrypt the signing keys (generated on first boot).
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=__strong_random_passphrase__

### Mailer (production SMTP — e.g. your transactional provider)
MAILER_DSN=smtp://__user__:__password__@__smtp_host__:587

### Google OAuth (leave empty if disabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

### Frontend / routing
FRONTEND_URL=https://__DOMAIN__
DEFAULT_URI=https://__DOMAIN__
PASSWORD_ROTATION_DAYS=60
