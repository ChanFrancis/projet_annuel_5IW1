# Valeurs par défaut de l'application (versionné).
# Les VRAIS secrets vont dans .env.local (git-ignored). Voir .env.example.
# En dev, docker-compose surcharge DATABASE_URL / REDIS_URL / MAILER_DSN / APP_SECRET.

APP_ENV=dev
APP_SECRET=change_me_in_env_local
APP_DEBUG=1

# PostgreSQL (surchargé par docker-compose en dev)
DATABASE_URL="postgresql://dev_user:dev_password@postgres:5432/copot_dev?serverVersion=16&charset=utf8"

# Redis
REDIS_URL=redis://redis:6379

# Mailer (Mailhog en dev, surchargé par docker-compose)
MAILER_DSN=smtp://mailhog:1025

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# JWT — la passphrase réelle va dans .env.local (les clés .pem sont git-ignored)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_env_local

# Google OAuth (scaffold — remplir dans .env.local pour activer)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs / divers
FRONTEND_URL=http://localhost:5173
DEFAULT_URI=http://localhost
PASSWORD_ROTATION_DAYS=60
